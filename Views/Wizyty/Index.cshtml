@model IEnumerable<KlinikaMVC.Models.Wizyta>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p class="text-end mt-3">
    <a asp-action="Create" class="btn btn-success shadow-sm">+ Dodaj Wizytę</a>
</p>
<table class="table table-striped table-hover align-middle shadow-sm mt-3 bg-white rounded">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.DataWizyty)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Pacjent)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Terapeuta)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Status)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.DataWizyty)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Pacjent.Id)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Terapeuta.Id)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Status.Id)
            </td>
            <td class="text-end">
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edytuj</a>
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Szczegóły</a>
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Usuń</a>
            </td>
        </tr>
}
    </tbody>
</table>
