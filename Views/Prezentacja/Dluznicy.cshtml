@model IEnumerable<KlinikaMVC.Models.Pacjent>

@{
    ViewData["Title"] = "Raport Dłużników";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-danger text-white py-3">
            <h3 class="card-title mb-0 fw-bold">💰 Rejestr Największych Dłużników Kliniki</h3>
        </div>
        <div class="card-body bg-light p-4">
            <p class="text-muted fs-5">
                Poniższe zestawienie finansowe jest generowane w czasie rzeczywistym bezpośrednio przez procedurę składowaną 
                <code class="bg-white px-2 py-1 rounded text-danger fw-bold">sp_RaportDlugow</code> na silniku bazy danych SQL Server.
            </p>
            
            <div class="table-responsive mt-4">
                <table class="table table-striped table-hover align-middle bg-white rounded shadow-sm border">
                    <thead class="table-dark">
                        <tr>
                            <th style="width: 15%">ID Pacjenta</th>
                            <th>Imię</th>
                            <th>Nazwisko</th>
                            <th class="text-end" style="width: 20%">Łączny Dług</th>
                            <th class="text-center" style="width: 25%">Status Poziomu Uzależnienia</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold text-secondary">#@item.Id</td>
                                <td class="fw-semibold">@item.Imie</td>
                                <td class="fw-semibold">@item.Nazwisko</td>
                                <td class="text-end fw-bold text-danger fs-5">@item.Dlug.ToString("N2") zł</td>
                                <td class="text-center">
                                    @if (item.Dlug > 50000)
                                    {
                                        <span class="badge bg-danger px-3 py-2 fs-6 shadow-sm">Krytyczny (Zastawił dom)</span>
                                    }
                                    else if (item.Dlug > 10000)
                                    {
                                        <span class="badge bg-warning text-dark px-3 py-2 fs-6 shadow-sm">Poważny (Chwilówki)</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success px-3 py-2 fs-6 shadow-sm">Początkujący</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            
            <div class="mt-4 text-end">
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary px-4">Powrót do Pulpitu</a>
            </div>
        </div>
    </div>
</div>